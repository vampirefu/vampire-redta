<Window
    x:Class="ReDta.DxMainClient.Extend.Components.UpdatePromptWin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ReDta.DxMainClient.Extend.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="366"
    Height="195"
    AllowsTransparency="True"
    MouseLeftButtonDown="WinMove"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Border
        Background="#000000"
        ClipToBounds="True"
        CornerRadius="10">
        <Grid>
            <Image
                Height="8"
                VerticalAlignment="Top"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/top.png"
                Stretch="Fill" />
            <Image
                Height="8"
                VerticalAlignment="Bottom"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/bottom.png"
                Stretch="Fill" />
            <Image
                Width="8"
                Margin="0,8"
                HorizontalAlignment="Right"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/right.png"
                Stretch="Fill" />
            <Image
                Width="8"
                Margin="0,8"
                HorizontalAlignment="Left"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/left.png"
                Stretch="Fill" />
            <Image
                Width="8"
                Height="8"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/leftTop.png" />
            <Image
                Width="8"
                Height="8"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/leftBottom.png" />
            <Image
                Width="8"
                Height="8"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/rightTop.png" />
            <Image
                Width="8"
                Height="8"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/rightBottom.png" />
            <Border
                Margin="10"
                BorderBrush="Red"
                BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="auto" />
                        <RowDefinition />
                        <RowDefinition Height="36" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        FontFamily="楷体"
                        FontSize="20"
                        Foreground="Yellow">
                        更新提示
                    </TextBlock>
                    <Border
                        Grid.Row="1"
                        Margin="10,0"
                        BorderBrush="Red"
                        BorderThickness="0.5" />
                    <StackPanel Grid.Row="2" Margin="20,8,0,0">
                        <TextBlock
                            FontFamily="楷体"
                            FontSize="20"
                            Foreground="Yellow">
                            以下最新可用版本号：
                        </TextBlock>
                        <TextBlock
                            x:Name="tbx_version"
                            Margin="0,10"
                            FontFamily="楷体"
                            FontSize="20"
                            Foreground="Yellow" />
                        <TextBlock
                            FontFamily="楷体"
                            FontSize="20"
                            Foreground="Yellow">
                            请火速联系作者进行更新！
                        </TextBlock>
                    </StackPanel>
                    <Button
                        Grid.Row="3"
                        Width="88"
                        Height="28"
                        Padding="0"
                        BorderThickness="0"
                        Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid>
                                    <Image
                                        x:Name="buttonImage"
                                        Source="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/button.png"
                                        Stretch="Fill" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="楷体"
                                        FontSize="18"
                                        Foreground="Yellow">
                                        确定
                                    </TextBlock>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="Button.IsMouseOver" Value="True">
                                        <Setter TargetName="buttonImage" Property="Source" Value="pack://application:,,,/ReDta.DxMainClient.Extend;component/Resources/buttonCover.png" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
