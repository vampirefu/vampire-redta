<Window x:Class="MapGenerator.Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="地图生成器" Height="550" Width="800" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <!-- 现有基础动效 -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SlideInStoryboard">
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,50,0,0" To="0" Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
        <Storyboard x:Key="ProgressGlowStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity" From="0.3" To="1" Duration="0:0:0.8" AutoReverse="True"/>
        </Storyboard>

        <!-- 赛博风渐变背景笔刷 -->
        <LinearGradientBrush x:Key="NeonGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#061226" Offset="0"/>
            <GradientStop Color="#0b1b3f" Offset="0.5"/>
            <GradientStop Color="#001f3f" Offset="1"/>
        </LinearGradientBrush>

        <!-- 背景颜色缓变动画（目标：BgRect.Fill 的 GradientStops 的 Color） -->
        <Storyboard x:Key="BackgroundShift" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetName="BgRect" Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.GradientStops)[0].Color"
                            To="#0a1630" Duration="0:0:6" />
            <ColorAnimation Storyboard.TargetName="BgRect" Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.GradientStops)[1].Color"
                            To="#082042" Duration="0:0:6" />
            <ColorAnimation Storyboard.TargetName="BgRect" Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.GradientStops)[2].Color"
                            To="#00304f" Duration="0:0:6" />
        </Storyboard>

        <!-- 扫描线动画（从上到下重复） -->
        <Storyboard x:Key="ScanlineStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ScanlineTransform" Storyboard.TargetProperty="Y" From="-400" To="400" Duration="0:0:4"/>
        </Storyboard>

        <!-- 标题图标旋转（缓慢循环） -->
        <Storyboard x:Key="IconSpinStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="IconRotation" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:6"/>
        </Storyboard>

        <!-- 炫光按钮样式，基于 MaterialDesign 风格扩展发光效果 -->
        <Style x:Key="NeonButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00d8ff" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius" To="14" Duration="0:0:0.28"/>
                                <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity" To="0.9" Duration="0:0:0.28"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius" To="0" Duration="0:0:0.28"/>
                                <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity" To="0" Duration="0:0:0.28"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- 在窗口加载时启动背景、扫描线、图标旋转与淡入动画 -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource BackgroundShift}"/>
            <BeginStoryboard Storyboard="{StaticResource IconSpinStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource ScanlineStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border CornerRadius="12" BorderBrush="#0fd8ff" BorderThickness="1" Margin="8" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect Color="#001f3f" BlurRadius="28" ShadowDepth="0" Opacity="0.45"/>
            </Border.Effect>
            <Grid>
                <Rectangle x:Name="BgRect" RadiusX="12" RadiusY="12" Fill="{StaticResource NeonGradientBrush}" Stretch="Fill"/>

                <Rectangle x:Name="ScanlineRect" RadiusX="12" RadiusY="12" Opacity="0.06" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#66ffffff" Offset="0"/>
                            <GradientStop Color="#00ffffff" Offset="0.25"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="ScanlineTransform" Y="-400"/>
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Map" Width="28" Height="28" VerticalAlignment="Center" 
                                           Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,0,8,0">
                        <materialDesign:PackIcon.RenderTransform>
                            <RotateTransform x:Name="IconRotation" CenterX="14" CenterY="14"/>
                        </materialDesign:PackIcon.RenderTransform>
                    </materialDesign:PackIcon>
                    <TextBlock Text="地图生成器" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton" Style="{StaticResource MaterialDesignIconButton}" 
                            Click="MinimizeButton_Click" Margin="0,0,4,0">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource MaterialDesignIconButton}" 
                            Click="CloseButton_Click">
                        <materialDesign:PackIcon Kind="WindowClose" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Grid>

            <materialDesign:Card Grid.Row="1" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Folder" Width="20" Height="20" VerticalAlignment="Center" 
                                                Foreground="{DynamicResource SecondaryHueLightBrush}" Margin="0,0,8,0"/>
                        <TextBox x:Name="ToolPathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="工具路径"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" VerticalAlignment="Center"/>
                        <Button x:Name="BrowseToolPathButton" Grid.Column="2" Content="浏览" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="8,0,0,0" 
                                Click="BrowseToolPathButton_Click" MinWidth="60"/>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="GamepadVariant" Width="20" Height="20" VerticalAlignment="Center" 
                                                Foreground="{DynamicResource SecondaryHueLightBrush}" Margin="0,0,8,0"/>
                        <TextBox x:Name="GameResourcePathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="游戏资源路径"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" VerticalAlignment="Center"/>
                        <Button x:Name="BrowseGameResourcePathButton" Grid.Column="2" Content="浏览" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="8,0,0,0" 
                                Click="BrowseGameResourcePathButton_Click" MinWidth="60"/>
                    </Grid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="气候类型" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                            <ComboBox x:Name="ClimateComboBox" Grid.Row="1" 
                                     Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,4,0,0">
                                <ComboBoxItem Content="温带 (TEMPERATE)" IsSelected="True"/>
                                <ComboBoxItem Content="温带岛屿 (TEMPERATE_Islands)"/>
                                <ComboBoxItem Content="城市 (NEWURBAN)"/>
                                <ComboBoxItem Content="沙漠 (DESERT)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Column="1" Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="玩家数量" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                            <ComboBox x:Name="PlayerCountComboBox" Grid.Row="1" 
                                     Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,4,0,0">
                                <ComboBoxItem Content="2人"/>
                                <ComboBoxItem Content="3人"/>
                                <ComboBoxItem Content="4人" IsSelected="True"/>
                                <ComboBoxItem Content="5人"/>
                                <ComboBoxItem Content="6人"/>
                                <ComboBoxItem Content="7人"/>
                                <ComboBoxItem Content="8人"/>
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="地图大小" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                            <ComboBox x:Name="MapSizeComboBox" Grid.Row="1" 
                                     Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,4,0,0">
                                <ComboBoxItem Content="小型"/>
                                <ComboBoxItem Content="中型" IsSelected="True"/>
                                <ComboBoxItem Content="大型"/>
                                <ComboBoxItem Content="超大"/>
                            </ComboBox>
                        </Grid>
                    </Grid>
                    <CheckBox x:Name="RandomDamageCheckBox" Content="随机建筑损伤" IsChecked="True" Margin="0,8,0,0"
                             Style="{StaticResource MaterialDesignCheckBox}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="3" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                        <Button x:Name="GenerateMapButton" Grid.Column="0" Content="生成随机地图" Height="40" 
                            Style="{StaticResource NeonButtonStyle}" Margin="0,0,8,0" 
                            Click="GenerateMapButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MapPlus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                        <Button x:Name="RenderThumbnailButton" Grid.Column="1" Content="渲染地图缩略图" Height="40" 
                            Style="{StaticResource NeonButtonStyle}" Margin="0,0,8,0" 
                            Click="RenderThumbnailButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Image" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                        <Button x:Name="ExtractPreviewButton" Grid.Column="2" Content="提取地图缩略图" Height="40" 
                            Style="{StaticResource NeonButtonStyle}" 
                            Click="ExtractPreviewButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ImageSearch" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="4" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ProgressTextBlock" Grid.Row="0" Text="就绪" Margin="0,0,0,8"
                              FontSize="14" Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="6" Minimum="0" Maximum="100" Value="0"
                                Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,0,0,10">
                        <ProgressBar.Effect>
                            <DropShadowEffect x:Name="ProgressGlow" Color="#FF9800" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                        </ProgressBar.Effect>
                    </ProgressBar>
                    <TextBox x:Name="LogTextBox" Grid.Row="2" IsReadOnly="True" 
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                            Height="100" TextWrapping="Wrap"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>