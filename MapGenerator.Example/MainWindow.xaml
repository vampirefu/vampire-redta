<Window x:Class="MapGenerator.Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="地图生成器" Height="650" Width="600" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SlideInStoryboard">
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,50,0,0" To="0" Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
        <Storyboard x:Key="ProgressGlowStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity" From="0.3" To="1" Duration="0:0:0.8" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="12" Background="#1a1a2e" BorderBrush="#4a4a6a" BorderThickness="1" Margin="8">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Map" Width="28" Height="28" VerticalAlignment="Center" 
                                           Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,0,8,0">
                        <materialDesign:PackIcon.RenderTransform>
                            <RotateTransform x:Name="IconRotation" CenterX="14" CenterY="14"/>
                        </materialDesign:PackIcon.RenderTransform>
                    </materialDesign:PackIcon>
                    <TextBlock Text="地图生成器" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton" Style="{StaticResource MaterialDesignIconButton}" 
                            Click="MinimizeButton_Click" Margin="0,0,4,0">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource MaterialDesignIconButton}" 
                            Click="CloseButton_Click">
                        <materialDesign:PackIcon Kind="WindowClose" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Grid>

            <materialDesign:Card Grid.Row="1" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Folder" Width="20" Height="20" VerticalAlignment="Center" 
                                                Foreground="{DynamicResource SecondaryHueLightBrush}" Margin="0,0,8,0"/>
                        <TextBox x:Name="ToolPathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="工具路径"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" VerticalAlignment="Center"/>
                        <Button x:Name="BrowseToolPathButton" Grid.Column="2" Content="浏览" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="8,0,0,0" 
                                Click="BrowseToolPathButton_Click" MinWidth="60"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="GamepadVariant" Width="20" Height="20" VerticalAlignment="Center" 
                                                Foreground="{DynamicResource SecondaryHueLightBrush}" Margin="0,0,8,0"/>
                        <TextBox x:Name="GameResourcePathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="游戏资源路径"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" VerticalAlignment="Center"/>
                        <Button x:Name="BrowseGameResourcePathButton" Grid.Column="2" Content="浏览" 
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="8,0,0,0" 
                                Click="BrowseGameResourcePathButton_Click" MinWidth="60"/>
                    </Grid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="气候类型" VerticalAlignment="Center" Margin="0,6,12,6"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <ComboBox x:Name="ClimateComboBox" Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,6,0,6">
                        <ComboBoxItem Content="温带 (TEMPERATE)" IsSelected="True"/>
                        <ComboBoxItem Content="温带岛屿 (TEMPERATE_Islands)"/>
                        <ComboBoxItem Content="城市 (NEWURBAN)"/>
                        <ComboBoxItem Content="沙漠 (DESERT)"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="玩家数量" VerticalAlignment="Center" Margin="0,6,12,6"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <ComboBox x:Name="PlayerCountComboBox" Grid.Row="1" Grid.Column="1" 
                             Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,6,0,6">
                        <ComboBoxItem Content="2人"/>
                        <ComboBoxItem Content="3人"/>
                        <ComboBoxItem Content="4人" IsSelected="True"/>
                        <ComboBoxItem Content="5人"/>
                        <ComboBoxItem Content="6人"/>
                        <ComboBoxItem Content="7人"/>
                        <ComboBoxItem Content="8人"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="地图大小" VerticalAlignment="Center" Margin="0,6,12,6"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <ComboBox x:Name="MapSizeComboBox" Grid.Row="2" Grid.Column="1" 
                             Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,6,0,6">
                        <ComboBoxItem Content="小型"/>
                        <ComboBoxItem Content="中型" IsSelected="True"/>
                        <ComboBoxItem Content="大型"/>
                        <ComboBoxItem Content="超大"/>
                    </ComboBox>

                    <CheckBox x:Name="RandomDamageCheckBox" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                             Content="随机建筑损伤" IsChecked="True" Margin="0,6,0,6"
                             Style="{StaticResource MaterialDesignCheckBox}"/>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="3" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <StackPanel>
                    <Button x:Name="GenerateMapButton" Content="生成随机地图" Height="40" 
                            Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,4,0,4" 
                            Click="GenerateMapButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MapPlus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="RenderThumbnailButton" Content="渲染地图缩略图" Height="40" 
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Margin="0,4,0,4" 
                            Click="RenderThumbnailButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Image" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="ExtractPreviewButton" Content="提取地图缩略图" Height="40" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,4,0,4" 
                            Click="ExtractPreviewButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ImageSearch" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="4" Margin="0,0,0,10" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ProgressTextBlock" Grid.Row="0" Text="就绪" Margin="0,0,0,8"
                              FontSize="14" Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="6" Minimum="0" Maximum="100" Value="0"
                                Style="{StaticResource MaterialDesignLinearProgressBar}">
                        <ProgressBar.Effect>
                            <DropShadowEffect x:Name="ProgressGlow" Color="#2196F3" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                        </ProgressBar.Effect>
                    </ProgressBar>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="5" Padding="12">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="日志" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <TextBox x:Name="LogTextBox" Grid.Row="1" IsReadOnly="True" 
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                            Height="100" TextWrapping="Wrap"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
