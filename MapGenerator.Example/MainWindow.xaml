<Window x:Class="MapGenerator.Example.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="地图生成器" Height="550" Width="800" WindowStartupLocation="CenterScreen"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    ResizeMode="CanResizeWithGrip" MouseDown="Window_MouseDown" MouseMove="Window_MouseMove" UseLayoutRounding="True" SnapsToDevicePixels="True"
    >
    <Window.Resources>
        <!-- 基础动效 -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SlideInStoryboard">
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,28,0,0" To="0" Duration="0:0:0.36">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
        <Storyboard x:Key="ProgressGlowStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity" From="0.2" To="0.9" Duration="0:0:0.8" AutoReverse="True"/>
        </Storyboard>

        <!-- 亮暖配色资源（简约、温暖、科技感） -->
        <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="#3B2E2A"/>
        <SolidColorBrush x:Key="SecondaryHueLightBrush" Color="#7A4B2B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF8A00"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFDF7"/>

        <!-- 背景渐变（暖色） -->
        <LinearGradientBrush x:Key="WarmGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFDF7" Offset="0"/>
            <GradientStop Color="#FFF6EA" Offset="0.6"/>
            <GradientStop Color="#FFF0E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- 背景颜色缓变（微妙波动） -->
        <Storyboard x:Key="BackgroundShift" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetName="BgRect" Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.GradientStops)[0].Color"
                            To="#FFFEF9" Duration="0:0:9" />
            <ColorAnimation Storyboard.TargetName="BgRect" Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.GradientStops)[1].Color"
                            To="#FFF8ED" Duration="0:0:9" />
            <ColorAnimation Storyboard.TargetName="BgRect" Storyboard.TargetProperty="(Rectangle.Fill).(LinearGradientBrush.GradientStops)[2].Color"
                            To="#FFF2E4" Duration="0:0:9" />
        </Storyboard>

        <!-- 扫描光条（用于轻微科技感移动高光） -->
        <Storyboard x:Key="ScanlineStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ScanlineTransform" Storyboard.TargetProperty="X" From="-900" To="900" Duration="0:0:6"/>
        </Storyboard>

        

        <!-- 按钮样式：暖色主色，带点击波纹与发光 -->
        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF8A00" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF8A00" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Ellipse x:Name="PART_Ripple" Width="240" Height="240" Opacity="0" RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="#33FFFFFF"/>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="0" ScaleY="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_Ripple" Storyboard.TargetProperty="Opacity" From="0.35" To="0" Duration="0:0:0.6"/>
                                        <DoubleAnimation Storyboard.TargetName="PART_Ripple" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleX)" From="0" To="1" Duration="0:0:0.6"/>
                                        <DoubleAnimation Storyboard.TargetName="PART_Ripple" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleY)" From="0" To="1" Duration="0:0:0.6"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="20" Duration="0:0:0.22"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.36" Duration="0:0:0.22"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="0" Duration="0:0:0.22"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0" Duration="0:0:0.22"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ComboBox items: ensure dropdown items use light background and readable foreground -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- 简化滚动条外观 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        </Style>

        <!-- 增强动画资源：平移、快速扫描线、粒子与图标脉冲 -->
        <Storyboard x:Key="BackgroundPanStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BgPanTransform" Storyboard.TargetProperty="X" From="-6" To="6" Duration="0:0:12"/>
            <DoubleAnimation Storyboard.TargetName="BgPanTransform" Storyboard.TargetProperty="Y" From="-4" To="4" Duration="0:0:10"/>
        </Storyboard>

        <Storyboard x:Key="FastScanlineStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Scanline2Transform" Storyboard.TargetProperty="X" From="-900" To="900" Duration="0:0:3"/>
        </Storyboard>

        <Storyboard x:Key="IconSpinStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="TitleIconRotateTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:6">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="TitleIconPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="TitleIconScaleTransform" Storyboard.TargetProperty="ScaleX" From="1" To="1.08" Duration="0:0:1.6"/>
            <DoubleAnimation Storyboard.TargetName="TitleIconScaleTransform" Storyboard.TargetProperty="ScaleY" From="1" To="1.08" Duration="0:0:1.6"/>
        </Storyboard>

        <Storyboard x:Key="Particle1Storyboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="Particle1Transform" Storyboard.TargetProperty="X" From="-120" To="900" Duration="0:0:18"/>
            <DoubleAnimation Storyboard.TargetName="Particle1" Storyboard.TargetProperty="Opacity" From="0" To="0.45" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>

        <Storyboard x:Key="Particle2Storyboard" RepeatBehavior="Forever" BeginTime="0:0:3">
            <DoubleAnimation Storyboard.TargetName="Particle2Transform" Storyboard.TargetProperty="X" From="900" To="-200" Duration="0:0:22"/>
            <DoubleAnimation Storyboard.TargetName="Particle2" Storyboard.TargetProperty="Opacity" From="0" To="0.38" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>

        <Storyboard x:Key="Particle3Storyboard" RepeatBehavior="Forever" BeginTime="0:0:5">
            <DoubleAnimation Storyboard.TargetName="Particle3Transform" Storyboard.TargetProperty="X" From="-200" To="900" Duration="0:0:16"/>
            <DoubleAnimation Storyboard.TargetName="Particle3" Storyboard.TargetProperty="Opacity" From="0" To="0.32" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>

        <Storyboard x:Key="Particle4Storyboard" RepeatBehavior="Forever" BeginTime="0:0:7">
            <DoubleAnimation Storyboard.TargetName="Particle4Transform" Storyboard.TargetProperty="X" From="900" To="-200" Duration="0:0:20"/>
            <DoubleAnimation Storyboard.TargetName="Particle4" Storyboard.TargetProperty="Opacity" From="0" To="0.28" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <!-- 在 Window 加载时启动增强动画 -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource BackgroundShift}"/>
            <BeginStoryboard Storyboard="{StaticResource BackgroundPanStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource ScanlineStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource FastScanlineStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource IconSpinStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource TitleIconPulseStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource Particle1Storyboard}"/>
            <BeginStoryboard Storyboard="{StaticResource Particle2Storyboard}"/>
            <BeginStoryboard Storyboard="{StaticResource Particle3Storyboard}"/>
            <BeginStoryboard Storyboard="{StaticResource Particle4Storyboard}"/>
        </EventTrigger>
    </Window.Triggers>
    <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Border CornerRadius="12" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Margin="8" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect Color="#A8A0A0" BlurRadius="14" ShadowDepth="0" Opacity="0.12"/>
            </Border.Effect>
            <Grid>
                <Rectangle x:Name="BgRect" RadiusX="12" RadiusY="12" Fill="{StaticResource WarmGradientBrush}" Stretch="Fill">
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="BgPanTransform" X="0" Y="0"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- 背景漂浮光晕 -->
                <Ellipse x:Name="Halo1" Width="420" Height="220" Opacity="0.18" IsHitTestVisible="False" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="60,20,0,0" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.3,0.3">
                            <GradientStop Color="#FFF8D1" Offset="0"/>
                            <GradientStop Color="#00FFF8D1" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="28"/>
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Halo1Transform" X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- 粒子层 -->
                <Canvas x:Name="ParticleLayer" IsHitTestVisible="False">
                    <Ellipse x:Name="Particle1" Width="18" Height="18" Fill="#FFF2C6" Opacity="0.0" Canvas.Left="-80" Canvas.Top="110" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Particle1Transform" X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle2" Width="12" Height="12" Fill="#FFF0A0" Opacity="0.0" Canvas.Left="900" Canvas.Top="60" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Particle2Transform" X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle3" Width="14" Height="14" Fill="#FFE6B8" Opacity="0.0" Canvas.Left="-60" Canvas.Top="180" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Particle3Transform" X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle4" Width="10" Height="10" Fill="#FFDDA0" Opacity="0.0" Canvas.Left="900" Canvas.Top="220" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="Particle4Transform" X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>

                <!-- 原扫描光条 -->
                <Rectangle x:Name="ScanlineRect" RadiusX="12" RadiusY="12" Opacity="0.08" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#33FFFFFF" Offset="0.45"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.55"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="ScanlineTransform" X="-900"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- 第二快速扫描线 -->
                <Rectangle x:Name="ScanlineRect2" RadiusX="12" RadiusY="12" Opacity="0.05" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#66FFFFFF" Offset="0.3"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="Scanline2Transform" X="-900"/>
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon x:Name="TitleIcon" Kind="Map" Width="28" Height="28" VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryHueLightBrush}" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                        <materialDesign:PackIcon.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="TitleIconScaleTransform" ScaleX="1" ScaleY="1"/>
                                <RotateTransform x:Name="TitleIconRotateTransform" Angle="0"/>
                            </TransformGroup>
                        </materialDesign:PackIcon.RenderTransform>
                    </materialDesign:PackIcon>
                    <TextBlock Text="地图生成器" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"
                              Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton" Style="{StaticResource MaterialDesignIconButton}" 
                            Click="MinimizeButton_Click" Margin="0,0,4,0">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource MaterialDesignIconButton}" 
                            Click="CloseButton_Click">
                        <materialDesign:PackIcon Kind="WindowClose" Width="18" Height="18" Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <materialDesign:Card Grid.Row="1" Margin="0,0,0,10" Padding="12" Background="{StaticResource CardBackgroundBrush}">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="Folder" Width="20" Height="20" VerticalAlignment="Center" 
                                                Foreground="{DynamicResource SecondaryHueLightBrush}" Margin="0,0,8,0"/>
                        <TextBox x:Name="ToolPathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="工具路径"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" VerticalAlignment="Center"
                                Background="{StaticResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryHueLightBrush}"
                                BorderBrush="#E6C3A3" BorderThickness="1" Padding="8" MinHeight="36"/>
                        <Button x:Name="BrowseToolPathButton" Grid.Column="2" Content="浏览" 
                                Style="{StaticResource NeonButtonStyle}" Margin="8,0,0,0" 
                                Click="BrowseToolPathButton_Click" Width="60" Height="32"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="GamepadVariant" Width="20" Height="20" VerticalAlignment="Center" 
                                                Foreground="{DynamicResource SecondaryHueLightBrush}" Margin="0,0,8,0"/>
                        <TextBox x:Name="GameResourcePathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="游戏资源路径"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}" VerticalAlignment="Center"
                                Background="{StaticResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryHueLightBrush}"
                                BorderBrush="#E6C3A3" BorderThickness="1" Padding="8" MinHeight="36"/>
                        <Button x:Name="BrowseGameResourcePathButton" Grid.Column="2" Content="浏览" 
                                Style="{StaticResource NeonButtonStyle}" Margin="8,0,0,0" 
                                Click="BrowseGameResourcePathButton_Click" Width="60" Height="32"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2" Margin="0,0,0,10" Padding="12" Background="{StaticResource CardBackgroundBrush}">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0" Orientation="Vertical">
                            <TextBlock Text="气候类型" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                            <ComboBox x:Name="ClimateComboBox" 
                                     Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,4,0,0"
                                     Background="{StaticResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryHueLightBrush}"
                                     BorderBrush="#E6C3A3" BorderThickness="1" Padding="8">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightBrush}"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="温带 (TEMPERATE)" IsSelected="True"/>
                                <ComboBoxItem Content="温带岛屿 (TEMPERATE_Islands)"/>
                                <ComboBoxItem Content="城市 (NEWURBAN)"/>
                                <ComboBoxItem Content="沙漠 (DESERT)"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0" Orientation="Vertical">
                            <TextBlock Text="玩家数量" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                            <ComboBox x:Name="PlayerCountComboBox" 
                                     Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,4,0,0"
                                     Background="{StaticResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryHueLightBrush}"
                                     BorderBrush="#E6C3A3" BorderThickness="1" Padding="8">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightBrush}"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="2人"/>
                                <ComboBoxItem Content="3人"/>
                                <ComboBoxItem Content="4人" IsSelected="True"/>
                                <ComboBoxItem Content="5人"/>
                                <ComboBoxItem Content="6人"/>
                                <ComboBoxItem Content="7人"/>
                                <ComboBoxItem Content="8人"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Vertical">
                            <TextBlock Text="地图大小" VerticalAlignment="Center" Margin="0,0,8,0"
                                      Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                            <ComboBox x:Name="MapSizeComboBox" 
                                     Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,4,0,0"
                                     Background="{StaticResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryHueLightBrush}"
                                     BorderBrush="#E6C3A3" BorderThickness="1" Padding="8">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueLightBrush}"/>
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="小型"/>
                                <ComboBoxItem Content="中型" IsSelected="True"/>
                                <ComboBoxItem Content="大型"/>
                                <ComboBoxItem Content="超大"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <CheckBox x:Name="RandomDamageCheckBox" Content="随机建筑损伤" IsChecked="True" Margin="0,8,0,0"
                             Style="{StaticResource MaterialDesignCheckBox}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="3" Margin="0,0,0,10" Padding="12" Background="{StaticResource CardBackgroundBrush}">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="GenerateMapButton" Grid.Column="0" Content="生成随机地图" Height="40" 
                            Style="{StaticResource NeonButtonStyle}" Margin="0,0,8,0" 
                            Click="GenerateMapButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="MapPlus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="RenderThumbnailButton" Grid.Column="1" Content="渲染地图缩略图" Height="40" 
                            Style="{StaticResource NeonButtonStyle}" Margin="0,0,8,0" 
                            Click="RenderThumbnailButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Image" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="ExtractPreviewButton" Grid.Column="2" Content="提取地图缩略图" Height="40" 
                            Style="{StaticResource NeonButtonStyle}" 
                            Click="ExtractPreviewButton_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="ImageSearch" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="4" Padding="12" Background="{StaticResource CardBackgroundBrush}">
                <materialDesign:Card.Style>
                    <Style TargetType="materialDesign:Card">
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard Storyboard="{StaticResource SlideInStoryboard}"/>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </materialDesign:Card.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ProgressTextBlock" Grid.Row="0" Text="就绪" Margin="0,0,0,8"
                              FontSize="14" Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                    <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="6" Minimum="0" Maximum="100" Value="0"
                                Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,0,0,10">
                        <ProgressBar.Effect>
                            <DropShadowEffect x:Name="ProgressGlow" Color="#FF8A00" BlurRadius="8" ShadowDepth="0" Opacity="0"/>
                        </ProgressBar.Effect>
                    </ProgressBar>
                        <TextBox x:Name="LogTextBox" Grid.Row="2" IsReadOnly="True" 
                            VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" 
                            Height="100" TextWrapping="Wrap"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Background="{StaticResource CardBackgroundBrush}" Foreground="{DynamicResource PrimaryHueLightBrush}"
                            BorderBrush="#E6C3A3" BorderThickness="1" Padding="8"/>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
