<Window
    x:Class="Vampire.ReDta.Login.LoginWin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Vampire.ReDta.Login"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="360"
    Height="500"
    AllowsTransparency="True"
    MouseLeftButtonDown="WinMove"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="DeepPurple"
                    SecondaryColor="Lime" />

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border>
        <Border.Background>
            <ImageBrush ImageSource="pack://application:,,,/ReDta.Login;component/Resources/bg.png" />
        </Border.Background>
        <Grid>
            <Image
                Width="80"
                Margin="0,60,0,0"
                VerticalAlignment="Top"
                Source="pack://application:,,,/ReDta.Login;component/Resources/logo.png" />
            <Rectangle
                Width="280"
                Height="240"
                Margin="0,80"
                VerticalAlignment="Bottom"
                Fill="White"
                RadiusX="10"
                RadiusY="10">
                <Rectangle.Effect>
                    <DropShadowEffect
                        BlurRadius="15"
                        Direction="0"
                        RenderingBias="Quality"
                        ShadowDepth="1"
                        Color="#FFBBBBBB" />
                </Rectangle.Effect>
            </Rectangle>
            <Grid
                Height="240"
                Margin="35,80"
                VerticalAlignment="Bottom">
                <Label
                    Margin="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Content="登录"
                    FontSize="18"
                    Foreground="Gray" />
                <StackPanel Margin="15" VerticalAlignment="Center">
                    <TextBox
                        x:Name="tbx_account"
                        Margin="0,10"
                        materialDesign:HintAssist.Hint="账号"
                        FontFamily="Champagne &amp; Limousines"
                        FontSize="18"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    <PasswordBox
                        x:Name="tbx_password"
                        Margin="0,10"
                        materialDesign:HintAssist.Hint="密码"
                        FontFamily="Champagne &amp; Limousines"
                        FontSize="18"
                        Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}" />
                    <CheckBox
                        x:Name="ckx_savePassword"
                        Margin="0,10,0,0"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignCheckBox}">
                        记住密码
                    </CheckBox>
                </StackPanel>
            </Grid>
            <Button
                x:Name="btn_login"
                Width="150"
                Margin="0,65"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                materialDesign:ButtonProgressAssist.IsIndeterminate="True"
                materialDesign:ButtonProgressAssist.IsIndicatorVisible="False"
                materialDesign:ButtonProgressAssist.Value="-1"
                Click="Login_Click"
                Content="登录"
                Style="{StaticResource MaterialDesignRaisedButton}" />
            <!--<TextBlock Text="忘记密码？" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="30" Foreground="Gray" Cursor="Hand"/>-->
            <TextBlock
                x:Name="tbk_loginInfo"
                Margin="0,0,0,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Foreground="Red"
                Visibility="Collapsed" />
            <Button
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{x:Null}"
                BorderBrush="{x:Null}"
                Click="Close_Click">
                <materialDesign:PackIcon Kind="Close" />
            </Button>
        </Grid>
    </Border>
</Window>
