<Project>
  <Target Name="PublishWinDesktopGLNative" AfterTargets="Publish" Condition="'$(Engine)' == 'UniversalGL' And $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
    <Message Importance="high" Text="Copying DesktopGLNative files"/>
    <Copy SourceFiles="$(OutputPath)SDL2.dll" DestinationFolder="$(PublishDir)" />
    <Copy SourceFiles="$(OutputPath)soft_oal.dll" DestinationFolder="$(PublishDir)" />
  </Target>

  <Target Name="RemoveCodeAnalysis" AfterTargets="Publish" Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows' And '$(Engine)' == 'WindowsDX'">
    <Message Importance="high" Text="Removing unnecessary CodeAnalysis files"/>
    <Delete Files="$(PublishDir)Microsoft.CodeAnalysis.CSharp.dll" />
    <Delete Files="$(PublishDir)Microsoft.CodeAnalysis.dll" />
    <Delete Files="$(PublishDir)Microsoft.CodeAnalysis.VisualBasic.dll" />
  </Target>

  <Target Name="RemoveWindowsDXNonWindowsBinaries" AfterTargets="Publish" Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows' And '$(Engine)' == 'WindowsDX'">
    <Message Importance="high" Text="Removing unnecessary WindowsDX files"/>
    <RemoveDir Directories="$(PublishDir)runtimes/debian-x64" />
    <RemoveDir Directories="$(PublishDir)runtimes/fedora-x64" />
    <RemoveDir Directories="$(PublishDir)runtimes/opensuse-x64" />
    <RemoveDir Directories="$(PublishDir)runtimes/osx" />
    <RemoveDir Directories="$(PublishDir)runtimes/rhel-x64" />
  </Target>

  <Target Name="RemoveWindowsGLNonWindowsBinaries" AfterTargets="Publish" Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows' And '$(Engine)' == 'WindowsGL'">
    <Message Importance="high" Text="Removing unnecessary WindowsGL files"/>
    <RemoveDir Directories="$(PublishDir)runtimes/linux-x64" />
    <RemoveDir Directories="$(PublishDir)runtimes/osx" />
  </Target>

  <Target Name="MoveCommonBinaries" AfterTargets="Publish">
    <Message Importance="high" Text="Moving common binaries"/>
    <ItemGroup>
      <CommonBinaries Include="$(PublishDir)ClientUpdater.dll" />
      <CommonBinaries Include="$(PublishDir)DiscordRPC.dll" />
      <CommonBinaries Include="$(PublishDir)Localization.dll" />
      <CommonBinaries Include="$(PublishDir)Localization.pdb" />
      <CommonBinaries Include="$(PublishDir)lzo.net.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.Abstractions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.Binder.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.CommandLine.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.EnvironmentVariables.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.FileExtensions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.Json.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Configuration.UserSecrets.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.DependencyInjection.Abstractions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.DependencyInjection.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.FileProviders.Abstractions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.FileProviders.Physical.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.FileSystemGlobbing.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Hosting.Abstractions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Hosting.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.Abstractions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.Configuration.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.Console.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.Debug.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.EventLog.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Logging.EventSource.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Options.ConfigurationExtensions.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Options.dll" />
      <CommonBinaries Include="$(PublishDir)Microsoft.Extensions.Primitives.dll" />
      <CommonBinaries Include="$(PublishDir)Newtonsoft.Json.Bson.dll" />
      <CommonBinaries Include="$(PublishDir)Newtonsoft.Json.dll" />
      <CommonBinaries Include="$(PublishDir)OpenMcdf.dll" />
      <CommonBinaries Include="$(PublishDir)Rampastring.Tools.dll" />
      <CommonBinaries Include="$(PublishDir)SixLabors.ImageSharp.dll" />
      <CommonBinaries Include="$(PublishDir)System.Net.Http.Formatting.dll" />
      <CommonBinaries Include="$(PublishDir)TextCopy.dll" />
    </ItemGroup>
    <Move SourceFiles="@(CommonBinaries)" DestinationFolder="$(PublishDir)../" Condition="Exists('%(Identity)')" />
  </Target>
</Project>