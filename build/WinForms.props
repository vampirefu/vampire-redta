<Project>
  <PropertyGroup>
    <TargetFramework Condition="'$(Engine)' != 'UniversalGL'">net8.0-windows</TargetFramework>
    <TargetFramework Condition="'$(Engine)' == 'UniversalGL'">net8.0</TargetFramework>
    <UseWindowsForms Condition="'$(Engine)' != 'UniversalGL'">true</UseWindowsForms>
  </PropertyGroup>
</Project>